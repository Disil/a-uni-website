---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Hero from '../../components/Hero.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout title="Manajemen Bisnis" description="Program S1 Manajemen Bisnis">
  <Navbar />
  
  <Hero 
    title="S1 Manajemen Bisnis" 
    subtitle="Memimpin bisnis di era digital dan global"
    ctaText="Daftar Sekarang"
    ctaLink="/admission"
  />
  
  <section class="py-5">
    <div class="container">
      <!-- Overview -->
      <div class="row mb-5">
        <div class="col-md-8">
          <h2 class="mb-4">Tentang Program</h2>
          <p class="lead">
            Program S1 Manajemen Bisnis dirancang untuk menghasilkan profesional bisnis 
            yang mampu berpikir strategis, memimpin tim, dan mengambil keputusan berbasis 
            data di era digital. Kurikulum kami menggabungkan teori manajemen terkini 
            dengan studi kasus nyata dari industri global.
          </p>
          <p>
            Lulusan program ini siap bekerja di berbagai sektor industri, dari perusahaan 
            multinasional, startup teknologi, hingga UMKM, dengan kemampuan entrepreneurship 
            dan leadership yang kuat.
          </p>
        </div>
        <div class="col-md-4">
          <div class="card bg-light">
            <div class="card-body">
              <h5 class="card-title">Informasi Singkat</h5>
              <ul class="list-unstyled">
                <li><strong>Gelar:</strong> S.M (Sarjana Manajemen)</li>
                <li><strong>Durasi:</strong> 4 Tahun</li>
                <li><strong>Akreditasi:</strong> B (BANPT)</li>
                <li><strong>Daya Tampung:</strong> 200 mahasiswa/tahun</li>
                <li><strong>Biaya SPP:</strong> Rp 2.8 juta/semester</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <hr class="my-5" />

      <!-- Kurikulum -->
      <h2 class="mb-4">Kurikulum & Mata Kuliah Utama</h2>
      <div class="row mb-4">
        <div class="col-md-6">
          <h5 class="text-primary">Tahun 1-2: Business Fundamentals</h5>
          <ul>
            <li>Pengantar Manajemen & Bisnis</li>
            <li>Akuntansi Dasar</li>
            <li>Ekonomi Mikro & Makro</li>
            <li>Business Mathematics & Statistics</li>
            <li>Komunikasi Bisnis</li>
          </ul>
        </div>
        <div class="col-md-6">
          <h5 class="text-primary">Tahun 3-4: Management Specialization</h5>
          <ul>
            <li>Strategic Management</li>
            <li>Marketing Management</li>
            <li>Financial Management & Investment</li>
            <li>Human Resource Management</li>
            <li>Business Analysis & Consulting Project</li>
          </ul>
        </div>
      </div>

      <hr class="my-5" />

      <!-- Konsentrasi -->
      <h2 class="mb-4">Pilihan Konsentrasi</h2>
      <div class="row g-4">
        <div class="col-md-6">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">📊 Management</h5>
              <p class="card-text">Kepemimpinan organisasi, strategic planning, dan operations management.</p>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">📈 Finance & Investment</h5>
              <p class="card-text">Manajemen keuangan, investasi, pasar modal, dan analisis laporan keuangan.</p>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">🎯 Marketing</h5>
              <p class="card-text">Digital marketing, brand management, consumer behavior, dan market research.</p>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card">
            <div class="card-body">
              <h5 class="card-title">👥 Human Resources</h5>
              <p class="card-text">Talent management, organizational development, dan employee relations.</p>
            </div>
          </div>
        </div>
      </div>

      <hr class="my-5" />

      <!-- Lulusan -->
      <h2 class="mb-4">Prospek Karir Lulusan</h2>
      <div class="row g-4">
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">💼 Management Consultant</h6>
              <p class="card-text small">Memberikan solusi strategis untuk peningkatan performa bisnis klien.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">📊 Financial Analyst</h6>
              <p class="card-text small">Analisis finansial, forecasting, dan investment recommendations.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">🎯 Marketing Manager</h6>
              <p class="card-text small">Strategi marketing, brand positioning, dan campaign management.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">👥 HR Manager</h6>
              <p class="card-text small">Rekrutmen, training, performance management, dan employee development.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">🚀 Entrepreneur</h6>
              <p class="card-text small">Memulai dan mengelola startup atau UMKM sendiri.</p>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card">
            <div class="card-body">
              <h6 class="card-title">📋 Operations Manager</h6>
              <p class="card-text small">Optimalisasi proses bisnis, supply chain, dan efisiensi operasional.</p>
            </div>
          </div>
        </div>
      </div>

      <hr class="my-5" />

      <!-- Pencapaian Lulusan -->
      <h2 class="mb-4">Pencapaian Alumni</h2>
      <div class="row">
        <div class="col-md-3 text-center mb-4">
          <h4 class="text-primary">2000+</h4>
          <p>Alumni yang tersebar di berbagai perusahaan multinasional</p>
        </div>
        <div class="col-md-3 text-center mb-4">
          <h4 class="text-primary">500+</h4>
          <p>Alumni yang menjadi entrepreneur sukses</p>
        </div>
        <div class="col-md-3 text-center mb-4">
          <h4 class="text-primary">95%</h4>
          <p>Tingkat employment dalam 6 bulan setelah lulus</p>
        </div>
        <div class="col-md-3 text-center mb-4">
          <h4 class="text-primary">100+</h4>
          <p>Alumni yang menduduki posisi C-level (CEO, CFO, CMO)</p>
        </div>
      </div>

      <hr class="my-5" />

      <!-- Program Tambahan -->
      <h2 class="mb-4">Program Tambahan & Pengembangan Karir</h2>
      <div class="row">
        <div class="col-md-6 mb-4">
          <h5>🏢 Internship Program</h5>
          <p>Program magang di perusahaan top nasional dan internasional untuk pengalaman praktis.</p>
        </div>
        <div class="col-md-6 mb-4">
          <h5>🎓 Case Study Kompetisi</h5>
          <p>Kompetisi case study dan business plan dengan hadiah menarik.</p>
        </div>
        <div class="col-md-6 mb-4">
          <h5>🌍 Student Exchange</h5>
          <p>Program pertukaran pelajar dengan universitas partner di Asia, Eropa, dan Amerika.</p>
        </div>
        <div class="col-md-6 mb-4">
          <h5>📜 Professional Certification</h5>
          <p>Program sertifikasi profesional seperti CPA, PMP, dan Digital Marketing.</p>
        </div>
      </div>

      <hr class="my-5" />

      <!-- CTA -->
      <div class="bg-primary text-white p-5 rounded text-center">
        <h3 class="mb-3">Mulai Perjalanan Karir Bisnis Anda Sekarang</h3>
        <p class="lead mb-4">Bergabunglah dengan ribuan profesional bisnis sukses kami.</p>
        <a href="/admission" class="btn btn-warning btn-lg">Daftar Sekarang</a>
        <a href="/contact" class="btn btn-light btn-lg ms-2">Hubungi Kami</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>