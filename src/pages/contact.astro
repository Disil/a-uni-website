---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Kontak" description="Hubungi kami untuk informasi lebih lanjut">
  <Navbar />
  
  <Hero 
    title="Hubungi Kami" 
    subtitle="Kami siap menjawab pertanyaan Anda"
  />
  
  <section class="py-5">
    <div class="container">
      <div class="row">
        <div class="col-md-6 mb-4">
          <h3>Formulir Kontak</h3>
          <form>
            <div class="mb-3">
              <label class="form-label">Nama Lengkap</label>
              <input type="text" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Email</label>
              <input type="email" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Subjek</label>
              <input type="text" class="form-control" required />
            </div>
            <div class="mb-3">
              <label class="form-label">Pesan</label>
              <textarea class="form-control" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn-primary">Kirim Pesan</button>
          </form>
        </div>
        
        <div class="col-md-6">
          <h3>Informasi Kontak</h3>
          <div class="mb-4">
            <h5>📍 Alamat</h5>
            <p>Jl. Universitas No. 1<br />Jakarta, Indonesia 12345</p>
          </div>
          <div class="mb-4">
            <h5>📞 Telepon</h5>
            <p>+62-21-1234567</p>
          </div>
          <div class="mb-4">
            <h5>📧 Email</h5>
            <p>info@universitas.ac.id</p>
          </div>
          <div class="mb-4">
            <h5>🕐 Jam Operasional</h5>
            <p>Senin - Jumat: 08:00 - 17:00<br />Sabtu: 08:00 - 12:00<br />Minggu: Tutup</p>
          </div>
          <h5>Ikuti Kami</h5>
          <a href="#" class="btn btn-sm btn-outline-primary me-2">Facebook</a>
          <a href="#" class="btn btn-sm btn-outline-primary me-2">Instagram</a>
          <a href="#" class="btn btn-sm btn-outline-primary">LinkedIn</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>